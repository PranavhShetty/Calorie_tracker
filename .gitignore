# Create .gitignore
New-Item .gitignore -ItemType File
```

Open `.gitignore` in VS Code and paste this:
```
# Python
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
.env

# ChromaDB data
chroma_data/
*.db
*.sqlite

# Node.js / React
node_modules/
frontend/node_modules/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Environment variables
.env
.env.local
.env.production